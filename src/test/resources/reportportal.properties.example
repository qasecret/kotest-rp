# Copy this file to reportportal.properties (kept out of git) and fill in your values.
# Used only by the opt-in live smoke tests (run with -Drp.live=true).
rp.endpoint = http://localhost:8082
rp.api.key = YOUR_API_KEY
rp.launch = testing_launch
rp.project = your_project

# Toggle reporting off without removing the extension:
# rp.enable = false

# Optional — reruns & distributed launches:
# rp.rerun = true
# rp.rerun.of = <previous-launch-uuid>
# rp.client.join = true                              # client elects/joins one shared launch
# rp.launch.uuid = <orchestrator-created-launch-uuid>  # report into an externally-managed launch
